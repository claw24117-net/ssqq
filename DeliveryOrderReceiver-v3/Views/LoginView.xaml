<UserControl x:Class="DeliveryOrderReceiver.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F5F5F5">
        <Border Background="White" Padding="32" CornerRadius="6"
                MaxWidth="440" VerticalAlignment="Center" HorizontalAlignment="Center"
                BorderBrush="#DDDDDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="배달 주문 수신기 v3.0.1"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="이메일" Margin="0,0,0,4"/>
                <TextBox x:Name="EmailBox" Margin="0,0,0,12"/>

                <TextBlock Text="패스워드" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12"/>

                <TextBlock Text="서버 주소" Margin="0,0,0,4"/>
                <TextBox x:Name="ServerUrlBox" Text="https://agent.zigso.kr" Margin="0,0,0,16"/>

                <CheckBox x:Name="SaveLoginInfoCheck" Content="로그인 정보 저장" Margin="0,0,0,4"/>
                <CheckBox x:Name="AutoLoginCheck" Content="자동 로그인" Margin="0,0,0,16"/>

                <Button x:Name="LoginButton" Content="로그인"
                        Background="{StaticResource PrimaryBrush}" Foreground="White"
                        FontWeight="SemiBold" Padding="12,8"
                        Click="LoginButton_Click"/>

                <TextBlock x:Name="StatusText" Margin="0,16,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
