<Window x:Class="DeliveryOrderReceiver.Views.AdminPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="관리자 비밀번호" SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8"/>
        <StackPanel x:Name="ConfirmPanel" Visibility="Collapsed">
            <TextBlock Text="비밀번호 확인" Margin="0,8,0,4"/>
            <PasswordBox x:Name="ConfirmBox"/>
        </StackPanel>
        <TextBlock x:Name="ErrorText" Foreground="#C73E1D" Margin="0,8,0,0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="취소" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="확인" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
