<UserControl x:Class="DeliveryOrderReceiver.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 상태 바 -->
        <Border Grid.Row="0" Background="#F0F4F8" Padding="12,8" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusDot" Grid.Column="0"
                         Width="12" Height="12" Margin="0,0,8,0"
                         Fill="{StaticResource MutedBrush}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusLabel" FontWeight="SemiBold" Text="대기 중"/>
                    <TextBlock x:Name="BranchLabel" Margin="16,0,0,0"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="로그아웃" Click="LogoutButton_Click" Margin="0,0,8,0"/>
                    <Button Content="설정" Click="SettingsButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- v3.0.3: 날짜 선택 + 주문 건수 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="조회 날짜:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <DatePicker x:Name="DateSelector" Width="140"
                        SelectedDateChanged="DateSelector_Changed"/>
            <TextBlock x:Name="OrderCountLabel" VerticalAlignment="Center"
                       Margin="12,0,0,0" Foreground="{StaticResource MutedBrush}"/>
        </StackPanel>

        <!-- 주문 목록 -->
        <DataGrid x:Name="OrdersGrid" Grid.Row="2" Margin="0,8,0,12"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" SelectionMode="Single"
                  RowHeight="28">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding Seq}" Width="40"/>
                <DataGridTextColumn Header="시각" Binding="{Binding ReceivedAtKst}" Width="150"/>
                <DataGridTextColumn Header="포트" Binding="{Binding Port}" Width="60"/>
                <DataGridTemplateColumn Header="내용" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Content}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Content}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="상태" Binding="{Binding UploadStatus}" Width="80"/>
                <DataGridTextColumn Header="오류" Binding="{Binding LastError}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 하단 액션 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left">
            <ComboBox x:Name="PortCombo" Width="120" Margin="0,0,8,0" IsEditable="True"/>
            <ComboBox x:Name="BaudCombo" Width="100" Margin="0,0,16,0">
                <ComboBoxItem>1200</ComboBoxItem>
                <ComboBoxItem>2400</ComboBoxItem>
                <ComboBoxItem>4800</ComboBoxItem>
                <ComboBoxItem IsSelected="True">9600</ComboBoxItem>
                <ComboBoxItem>19200</ComboBoxItem>
                <ComboBoxItem>38400</ComboBoxItem>
                <ComboBoxItem>57600</ComboBoxItem>
                <ComboBoxItem>115200</ComboBoxItem>
            </ComboBox>
            <Button Content="수신 시작" Click="StartButton_Click"
                    Background="{StaticResource SuccessBrush}" Foreground="White"/>
            <Button Content="수신 중지" Click="StopButton_Click"/>
            <Button Content="실패 건 재전송" Click="RetryButton_Click"/>
            <CheckBox x:Name="AutoStartCheck" Content="Windows 시작 시 자동 실행"
                      VerticalAlignment="Center" Margin="16,0,0,0"
                      Click="AutoStartCheck_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
