<UserControl x:Class="DeliveryOrderReceiver.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 상태 바 -->
        <Border Grid.Row="0" Background="#F0F4F8" Padding="12,8" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusDot" Grid.Column="0"
                         Width="12" Height="12" Margin="0,0,8,0"
                         Fill="{StaticResource MutedBrush}"/>
                <TextBlock x:Name="StatusLabel" Grid.Column="1"
                           VerticalAlignment="Center" FontWeight="SemiBold"
                           Text="대기 중"/>
                <Button Grid.Column="2" Content="설정" Click="SettingsButton_Click"/>
            </Grid>
        </Border>

        <!-- 주문 목록 -->
        <!-- r3: RowHeight 28 고정 + 내용 컬럼은 TemplateColumn 으로 한 줄 표시 (Bug 2) -->
        <DataGrid x:Name="OrdersGrid" Grid.Row="1" Margin="0,12,0,12"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" SelectionMode="Single"
                  RowHeight="28">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding Seq}" Width="40"/>
                <DataGridTextColumn Header="시각 (UTC)" Binding="{Binding ReceivedAt}" Width="180"/>
                <DataGridTextColumn Header="포트" Binding="{Binding Port}" Width="60"/>
                <DataGridTemplateColumn Header="내용" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Content}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Content}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="상태" Binding="{Binding UploadStatus}" Width="80"/>
                <DataGridTextColumn Header="오류" Binding="{Binding LastError}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 하단 액션 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
            <ComboBox x:Name="PortCombo" Width="120" Margin="0,0,8,0" IsEditable="True"/>
            <ComboBox x:Name="BaudCombo" Width="100" Margin="0,0,16,0">
                <ComboBoxItem>1200</ComboBoxItem>
                <ComboBoxItem>2400</ComboBoxItem>
                <ComboBoxItem>4800</ComboBoxItem>
                <ComboBoxItem IsSelected="True">9600</ComboBoxItem>
                <ComboBoxItem>19200</ComboBoxItem>
                <ComboBoxItem>38400</ComboBoxItem>
                <ComboBoxItem>57600</ComboBoxItem>
                <ComboBoxItem>115200</ComboBoxItem>
            </ComboBox>
            <Button Content="수신 시작" Click="StartButton_Click"
                    Background="{StaticResource SuccessBrush}" Foreground="White"/>
            <Button Content="수신 중지" Click="StopButton_Click"/>
            <Button Content="실패 건 재전송" Click="RetryButton_Click"/>
            <CheckBox x:Name="AutoStartCheck" Content="Windows 시작 시 자동 실행"
                      VerticalAlignment="Center" Margin="16,0,0,0"
                      Click="AutoStartCheck_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
